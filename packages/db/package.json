{
  "name": "@klub/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/validate-migrations.mjs && vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@klub/domain": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/node": "^22.7.5",
    "drizzle-kit": "^0.30.1",
    "typescript": "^6.0.3",
    "vitest": "^2.1.9"
  }
}
