# =============================================================================
# KLUB — Environment Variables
# Copy to .env.local (not committed) and fill in.
#
# All Bulk URLs verified against docs.bulk.trade as of Week 1 Day 1.
# Ref: docs/bulk-integration-notes.md
# =============================================================================

# -----------------------------------------------------------------------------
# Bulk Exchange — HTTP + WebSocket
# -----------------------------------------------------------------------------
# Production API endpoints. Bulk is a single-chain L0 running alongside
# Solana; there is one set of production URLs, with testnet accessible via
# a separate signed faucet endpoint (not a separate base URL).
BULK_HTTP_URL=https://exchange-api.bulk.trade/api/v1
NEXT_PUBLIC_BULK_WS_URL=wss://exchange-ws1.bulk.trade

# Testnet app URL — the hosted UI on Bulk for users to verify trades.
# Used for post-trade "view on Bulk" links in our toasts.
NEXT_PUBLIC_BULK_TESTNET_APP_URL=https://early.bulk.trade

# Network flag read by the web app and worker.
# Set to 'testnet' during Week 1-5 development, 'mainnet' from Week 6 on.
# This flag only controls UI labelling and logging; the API URL is the same.
NEXT_PUBLIC_BULK_NETWORK=testnet

# Builder Codes are currently staging-only. Configure both fields only when
# BULK_HTTP_URL points at https://staging-api.bulk.trade/api/v1.
BULK_BUILDER_CODE_RECIPIENT=
BULK_BUILDER_CODE_FEE_BPS=5

# -----------------------------------------------------------------------------
# Wallet — Solana (Bulk validators share Solana identity keys)
# -----------------------------------------------------------------------------
# Privy handles wallet connection UX. Supported adapters on Bulk: Phantom,
# Backpack, Solflare (any Solana wallet, since pubkeys are base58 Solana-style).
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=

# -----------------------------------------------------------------------------
# Ramp layer
# -----------------------------------------------------------------------------
NEXT_PUBLIC_COINBASE_ONRAMP_APP_ID=

# Experimental Ika+Encrypt ramp driver — feature-flagged off until both
# dependencies reach Alpha 1 on their respective networks.
NEXT_PUBLIC_EXPERIMENTAL_IKA_RAMP=false

# -----------------------------------------------------------------------------
# Data layer — Postgres + Redis
# -----------------------------------------------------------------------------
# Recommended for dev: Neon (Postgres free tier) + Upstash (Redis free tier).
# No Docker required.
#
# Format:
#   DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
#   REDIS_URL=rediss://default:PASSWORD@HOST:PORT     (Upstash uses rediss://)
DATABASE_URL=
REDIS_URL=

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
RESEND_API_KEY=
WAITLIST_AUDIENCE_ID=

# -----------------------------------------------------------------------------
# Agent-wallet keys — KMS wrap/unwrap
# -----------------------------------------------------------------------------
# Agent wallets are first-class on Bulk via POST /manageAgentWallet, with a
# canWithdraw:false invariant we enforce at provisioning. Keys live here:
#
# Production: AWS KMS key ARN wraps the agent-wallet Ed25519 secret at rest.
# Local dev:  symmetric 32-byte hex key used by a software AES wrapper.
#
# Exactly one must be set per environment.
AGENT_WALLET_KMS_KEY_ARN=
AGENT_WALLET_LOCAL_KEY=

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
