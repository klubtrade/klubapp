# =============================================================================
# KLUB — Environment Variables
# Copy to .env.local (not committed) and fill in.
#
# All Bulk URLs verified against docs.bulk.trade as of Week 1 Day 1.
# Ref: docs/bulk-integration-notes.md
# =============================================================================

# -----------------------------------------------------------------------------
# Bulk Exchange — HTTP + WebSocket
# -----------------------------------------------------------------------------
# Production API endpoints. Bulk is a single-chain L0 running alongside
# Solana; there is one set of production URLs, with testnet accessible via
# a separate signed faucet endpoint (not a separate base URL).
BULK_HTTP_URL=https://exchange-api.bulk.trade/api/v1
NEXT_PUBLIC_BULK_WS_URL=wss://exchange-ws1.bulk.trade

# Testnet app URL — the hosted UI on Bulk for users to verify trades.
# Used for post-trade "view on Bulk" links in our toasts.
NEXT_PUBLIC_BULK_TESTNET_APP_URL=https://early.bulk.trade

# Network flag read by the web app and worker.
# Set to 'testnet' during Week 1-5 development, 'mainnet' from Week 6 on.
# This flag only controls UI labelling and logging; the API URL is the same.
NEXT_PUBLIC_BULK_NETWORK=testnet

# Builder Codes are currently staging-only. Configure both fields only when
# BULK_HTTP_URL points at https://staging-api.bulk.trade/api/v1.
BULK_BUILDER_CODE_RECIPIENT=
BULK_BUILDER_CODE_FEE_BPS=5

# -----------------------------------------------------------------------------
# Wallet — Solana (Bulk validators share Solana identity keys)
# -----------------------------------------------------------------------------
# Privy handles wallet connection UX. Supported adapters on Bulk: Phantom,
# Backpack, Solflare (any Solana wallet, since pubkeys are base58 Solana-style).
# Public identifier; safe to expose in the browser bundle.
NEXT_PUBLIC_PRIVY_APP_ID=cmrp21bm502390cjxce8liowo
# Server-only. Set this in Privy/Railway, never commit a real value.
PRIVY_APP_SECRET=

# -----------------------------------------------------------------------------
# Ramp layer
# -----------------------------------------------------------------------------
NEXT_PUBLIC_COINBASE_ONRAMP_APP_ID=

# Experimental Ika+Encrypt ramp driver — feature-flagged off until both
# dependencies reach Alpha 1 on their respective networks.
NEXT_PUBLIC_EXPERIMENTAL_IKA_RAMP=false

# -----------------------------------------------------------------------------
# Basis Vault — Solana devnet
# -----------------------------------------------------------------------------
# Public frontend config. These can be exposed to the browser.
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_BASIS_VAULT_PROGRAM_ID=AZWFCfPmynzsrHevyUWgHpMDN5uJLAyGKRbAeUHe8scx
NEXT_PUBLIC_BASIS_VAULT_ADMIN=HssCPh192ZHgPu3zV3nFDDM4v6AM28fGV3tuJGy1K8zj
NEXT_PUBLIC_BASIS_VAULT_STRATEGY_AUTHORITY=9pQCDtJxfHDaJzyGsgNyDxakivx1vuD3XQPFYCtiajgh
NEXT_PUBLIC_BASIS_VAULT_USDC_MINT=724V1jFMAqpYNybSof6FLe5BENAuz3HXbDYD2mBDrai6
NEXT_PUBLIC_BASIS_VAULT_ADDRESS=BpjvJVuG9ki5DzVp1x6U7FwWS6HTrRccYAHuaFuZoiw5
NEXT_PUBLIC_BASIS_VAULT_USDC_ACCOUNT=8gt84p9Lubbx83qQkxSVuobayduBEhLvspwxz1pcS6i2
NEXT_PUBLIC_BASIS_VAULT_ADMIN_FEE_TOKEN_ACCOUNT=FXJW2kcBHk9bWqSgb5Q6oruZBfAfe1CBBCLdxrFTVvuh
NEXT_PUBLIC_BASIS_VAULT_MIN_DEPOSIT_USDC=100
NEXT_PUBLIC_BASIS_VAULT_MANAGEMENT_FEE_BPS=0
NEXT_PUBLIC_BASIS_VAULT_PERFORMANCE_FEE_BPS=10

# Server/operator-only. Never expose keypair JSON or seed phrases in browser env.
SOLANA_RPC_URL=
BASIS_VAULT_ADMIN_KEYPAIR_PATH=
BASIS_VAULT_STRATEGY_KEYPAIR_PATH=
BASIS_VAULT_MINT_AUTHORITY_KEYPAIR_PATH=
BASIS_VAULT_ADMIN_FEE_TOKEN_ACCOUNT=FXJW2kcBHk9bWqSgb5Q6oruZBfAfe1CBBCLdxrFTVvuh
BASIS_VAULT_STRATEGY_TOKEN_ACCOUNT=BM6svDbwtxujnD2vndMHc6vZNgTW1qeQqvoh4VtQeCng

# Realized-yield operator. The worker remains off unless explicitly enabled.
# It credits only positive net PnL verified from the configured Bulk account.
BASIS_OPERATOR_ENABLED=false
BASIS_OPERATOR_NETWORK=devnet
BASIS_BULK_STRATEGY_ACCOUNT=9pQCDtJxfHDaJzyGsgNyDxakivx1vuD3XQPFYCtiajgh
BASIS_STRATEGY_EXECUTION_ENABLED=false
BASIS_VAULT_PROGRAM_ID=AZWFCfPmynzsrHevyUWgHpMDN5uJLAyGKRbAeUHe8scx
BASIS_VAULT_STRATEGY_AUTHORITY=9pQCDtJxfHDaJzyGsgNyDxakivx1vuD3XQPFYCtiajgh
BASIS_VAULT_STRATEGY_AUTHORITY_SECRET=
BASIS_VAULT_USDC_MINT=724V1jFMAqpYNybSof6FLe5BENAuz3HXbDYD2mBDrai6
BASIS_VAULT_ADDRESS=BpjvJVuG9ki5DzVp1x6U7FwWS6HTrRccYAHuaFuZoiw5
BASIS_VAULT_USDC_ACCOUNT=8gt84p9Lubbx83qQkxSVuobayduBEhLvspwxz1pcS6i2
BASIS_MAX_CREDIT_PER_RUN_USDC=100

# Live trade-stream discovery scores observed Bulk accounts for /copy.
LEADER_DISCOVERY_SYMBOLS=

# -----------------------------------------------------------------------------
# Data layer — Postgres + Redis
# -----------------------------------------------------------------------------
# Recommended for dev: Neon (Postgres free tier) + Upstash (Redis free tier).
# No Docker required.
#
# Format:
#   DATABASE_URL=postgres://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require
#   REDIS_URL=rediss://default:PASSWORD@HOST:PORT     (Upstash uses rediss://)
DATABASE_URL=
REDIS_URL=

# -----------------------------------------------------------------------------
# Email
# -----------------------------------------------------------------------------
RESEND_API_KEY=
WAITLIST_AUDIENCE_ID=

# -----------------------------------------------------------------------------
# Agent-wallet keys — KMS wrap/unwrap
# -----------------------------------------------------------------------------
# Agent wallets are first-class on Bulk via POST /manageAgentWallet, with a
# canWithdraw:false invariant we enforce at provisioning. Keys live here:
#
# Production: AWS KMS key ARN wraps the agent-wallet Ed25519 secret at rest.
# Local dev:  symmetric 32-byte hex key used by a software AES wrapper.
#
# Exactly one must be set per environment.
AGENT_WALLET_KMS_KEY_ARN=
AGENT_WALLET_LOCAL_KEY=

# -----------------------------------------------------------------------------
# Notifications
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -----------------------------------------------------------------------------
# Site
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://klubapp-web.vercel.app
